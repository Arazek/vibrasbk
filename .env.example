# ── Traefik ────────────────────────────────────────────────────────────────────
# Domain that Traefik will route to the API (must have an A record → server IP)
API_HOST=vibrasbk.duckdns.org
# Traefik dashboard — host and BasicAuth credentials
TRAEFIK_DASHBOARD_HOST=traefik.yourdomain.com
# Generate with: echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$...

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mobile_app

# ── Keycloak ───────────────────────────────────────────────────────────────────
KEYCLOAK_HOSTNAME=auth.yourdomain.com
KEYCLOAK_REALM=vibras
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
# Keycloak-specific DB (can be same as POSTGRES_DB or separate)
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change-me

# ── pgAdmin ────────────────────────────────────────────────────────────────────
PGADMIN_HOSTNAME=pgadmin.yourdomain.com
PGADMIN_DEFAULT_EMAIL=admin@yourdomain.com
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_OAUTH_CLIENT_SECRET=change-me

# ── Webhook (automated deployments) ───────────────────────────────────────────
WEBHOOK_HOSTNAME=webhook.yourdomain.com
WEBHOOK_SECRET=change-me

# ── API ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── Google OAuth (optional) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/auth/google/callback

# ── Firebase FCM (optional) ────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
