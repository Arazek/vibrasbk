{
  "name": "mobile-app-template",
  "version": "1.0.0",
  "description": "B2C Mobile App Template - Ionic Angular + NestJS Monorepo",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "nx serve mobile-app",
    "start:api": "nx serve api",
    "build": "nx run-many --target=build --all",
    "build:app": "nx build mobile-app",
    "build:api": "nx build api",
    "test": "nx run-many --target=test --all",
    "test:app": "nx test mobile-app",
    "test:api": "nx test api",
    "e2e": "nx e2e mobile-app-e2e",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:setup": "cd apps/api && npm run db:setup",
    "docker:up": "docker compose up -d postgres",
    "docker:down": "docker compose down",
    "nx": "nx"
  },
